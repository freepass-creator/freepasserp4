{
  "rules": {
    "users": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
      "$uid": {
        ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "role": {
          ".validate": "(!data.exists() && newData.val() !== 'admin') || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "agent_payout_rate": {
          ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "status": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin' || newData.val() === 'pending' || (data.exists() && newData.val() === data.val())"
        },
        "company_code": {
          ".validate": "newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "agent_channel_code": {
          ".validate": "newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      }
    },

    "partners": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'provider')",
      ".indexOn": ["partner_code", "partner_type"]
    },
    "policies": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'provider')",
      ".indexOn": ["policy_code", "provider_company_code"]
    },
    "products": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
      ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
      ".indexOn": ["car_number", "product_code", "provider_company_code", "status", "vehicle_status"]
    },
    "rooms": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
      ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
      ".indexOn": ["product_uid", "agent_uid", "provider_uid", "provider_company_code", "agent_channel_code", "last_message_at"]
    },
    "messages": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
      ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'"
    },

    "contracts": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
      ".indexOn": ["product_uid", "partner_code", "contract_status", "agent_uid", "provider_company_code", "agent_channel_code", "created_at"]
    },
    "settlements": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('company_code').val() !== null && root.child('users').child(auth.uid).child('company_code').val() !== '' && query.orderByChild === 'provider_company_code' && query.equalTo === root.child('users').child(auth.uid).child('company_code').val()) || (query.orderByChild === 'agent_channel_code' && ((root.child('users').child(auth.uid).child('agent_channel_code').val() !== null && root.child('users').child(auth.uid).child('agent_channel_code').val() !== '' && query.equalTo === root.child('users').child(auth.uid).child('agent_channel_code').val()) || (root.child('users').child(auth.uid).child('company_code').val() !== null && root.child('users').child(auth.uid).child('company_code').val() !== '' && query.equalTo === root.child('users').child(auth.uid).child('company_code').val()))) || (query.orderByChild === 'agent_code' && ((root.child('users').child(auth.uid).child('user_code').val() !== null && root.child('users').child(auth.uid).child('user_code').val() !== '' && query.equalTo === root.child('users').child(auth.uid).child('user_code').val()) || query.equalTo === auth.uid)))",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["contract_code", "settlement_status", "provider_company_code", "agent_channel_code", "agent_code"]
    },
    "admin_settlements": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["settle_month", "settle_status", "contract_code"]
    },
    "customers": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (query.orderByChild === 'created_by' && query.equalTo === auth.uid))",
      "$id": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || data.child('created_by').val() === auth.uid)",
        ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (data.exists() && data.child('created_by').val() === auth.uid) || (!data.exists() && newData.child('created_by').val() === auth.uid))"
      },
      ".indexOn": ["phone", "name", "created_at", "created_by"]
    },

    "inquiries": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (query.orderByChild === 'agent_code' && query.equalTo === root.child('users').child(auth.uid).child('user_code').val()) || (query.orderByChild === 'agent_code' && query.equalTo === auth.uid))",
      "$id": {
        ".write": "auth != null || !data.exists()",
        ".validate": "newData.hasChildren(['visitor_name', 'visitor_phone', 'created_at']) && newData.child('visitor_name').isString() && newData.child('visitor_phone').isString() && newData.child('visitor_name').val().length > 0 && newData.child('visitor_phone').val().length >= 10 && newData.child('visitor_phone').val().length <= 13",
        "created_at": { ".validate": "newData.isNumber() && newData.val() <= now + 5000" },
        "visitor_name": { ".validate": "newData.val().length <= 30" },
        "message": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1000)" }
      },
      ".indexOn": ["product_uid", "agent_code", "status", "created_at"]
    },
    "contract_sign": {
      "$token": {
        ".read": true,
        ".write": "auth != null || (data.exists() && data.child('status').val() !== '서명완료')"
      }
    },
    "proposals": { ".read": true, ".write": "auth != null" },
    "proposal_views": {
      "$id": { ".read": "auth != null", ".write": "auth != null || !data.exists()" }
    },

    "terms": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "home_notices": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "car_models": { ".read": true, ".write": "auth != null", ".indexOn": ["maker", "model", "code"] },
    "vehicle_master": { ".read": "auth != null", ".write": "auth != null" },
    "color_master": { ".read": "auth != null", ".write": "auth != null" },
    "product_code_aliases": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "code_sequences": { ".read": "auth != null", ".write": "auth != null" },
    "input_codes": { ".read": "auth != null", ".write": "auth != null", ".indexOn": ["group_code"] },
    "counters": { ".read": "auth != null", ".write": "auth != null" },

    "fcm_tokens": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && $uid === auth.uid"
      }
    },
    "sms_cooldown": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": false
    },
    "audit_logs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["ts", "actor_uid", "collection"],
      "$auto": {
        ".write": "auth != null && newData.child('actor_uid').val() === auth.uid"
      }
    },
    "backup": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "api_keys": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "$other": { ".read": false, ".write": false },

    "v4": {
      "products": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
        ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
        ".indexOn": ["provider_company_code", "vehicle_status"]
      },
      "policies": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
        ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'provider')"
      },
      "partners": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
        ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'provider')",
        "$pid": {
          "fee_rate": {
            ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'"
          }
        }
      },
      "partners_private": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'agent' || root.child('users').child(auth.uid).child('role').val() === 'agent_admin' || root.child('users').child(auth.uid).child('role').val() === 'agent_manager')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        "$pid": {
          ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'provider' && root.child('users').child(auth.uid).child('company_code').val() !== null && root.child('users').child(auth.uid).child('company_code').val() !== '' && root.child('users').child(auth.uid).child('company_code').val() === $pid"
        }
      },
      "users": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
        "$uid": {
          ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          "role": { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'" },
          "agent_payout_rate": { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'" },
          "status": { ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin' || newData.val() === 'pending' || (data.exists() && newData.val() === data.val())" },
          "company_code": { ".validate": "newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'" },
          "agent_channel_code": { ".validate": "newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'" }
        }
      },
      "users_private": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        "$uid": {
          ".read": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          "agent_payout_rate": {
            ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin' || (data.exists() && newData.val() === data.val())"
          }
        }
      },
      "settlements": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('company_code').val() !== null && root.child('users').child(auth.uid).child('company_code').val() !== '' && query.orderByChild === 'provider_company_code' && query.equalTo === root.child('users').child(auth.uid).child('company_code').val()) || (query.orderByChild === 'agent_channel_code' && ((root.child('users').child(auth.uid).child('agent_channel_code').val() !== null && root.child('users').child(auth.uid).child('agent_channel_code').val() !== '' && query.equalTo === root.child('users').child(auth.uid).child('agent_channel_code').val()) || (root.child('users').child(auth.uid).child('company_code').val() !== null && root.child('users').child(auth.uid).child('company_code').val() !== '' && query.equalTo === root.child('users').child(auth.uid).child('company_code').val()))) || (query.orderByChild === 'agent_code' && ((root.child('users').child(auth.uid).child('user_code').val() !== null && root.child('users').child(auth.uid).child('user_code').val() !== '' && query.equalTo === root.child('users').child(auth.uid).child('user_code').val()) || query.equalTo === auth.uid)))",
        ".indexOn": ["provider_company_code", "agent_channel_code", "agent_code", "settlement_status", "contract_code"],
        "$sid": {
          ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
          "fee_amount": { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'" },
          "agent_payout": { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'" },
          "net_amount": { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'" },
          "fee_rate": { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'" }
        }
      },
      "admin_settlements": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      },
      "contracts": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
        ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
        ".indexOn": ["agent_uid", "provider_company_code", "agent_channel_code", "contract_status", "created_at"]
      },
      "customers": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (query.orderByChild === 'created_by' && query.equalTo === auth.uid))",
        ".indexOn": ["created_by", "phone", "name"],
        "$cid": {
          ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || data.child('created_by').val() === auth.uid)",
          ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (data.exists() && data.child('created_by').val() === auth.uid) || (!data.exists() && newData.child('created_by').val() === auth.uid))"
        }
      },
      "rooms": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
        ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
        ".indexOn": ["agent_uid", "provider_company_code", "agent_channel_code", "last_message_at"]
      },
      "messages": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
        ".indexOn": ["room_id"],
        "$message_id": {
          ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending' && newData.exists()",
          "sender_uid": { ".validate": "newData.val() === auth.uid" }
        }
      },
      "report": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        "$rid": {
          ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'"
        }
      },
      "quote": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
        ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('users').child(auth.uid).child('status').val() !== 'pending'",
        ".indexOn": ["agent_channel_code", "agent_code", "quote_code", "product_code"]
      },
      "$other": { ".read": false, ".write": false }
    }
  }
}
