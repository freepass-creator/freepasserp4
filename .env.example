# Firebase — freepasserp3 프로젝트 공유(회원·v3 실데이터 읽기).
# 비우면 LocalAdapter(localStorage) + seed 미리보기.
# 실데이터: API 키 채우고 NEXT_PUBLIC_DATA_BACKEND=rtdb
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=freepasserp3.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://freepasserp3-default-rtdb.asia-southeast1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=freepasserp3
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=freepasserp3.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=172664197996
NEXT_PUBLIC_FIREBASE_APP_ID=

# rtdb = v3 라이브 읽기 + 쓰기는 v4/ 오버레이만 (v3 원본 무변경)
# firestore = v4 Firestore (미사용 시 비움)
# 비움/기타 = Local + seed
NEXT_PUBLIC_DATA_BACKEND=rtdb
